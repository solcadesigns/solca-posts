---
// Blog index page: /blog
// Lists posts grouped by category, newest first.
// Posts with pubDate in the future are hidden until their date arrives (SSR per request).
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// SSR so the pubDate filter runs on every request against the current time.
// This lets us pre-deploy a month's worth of posts and have each one go live on its own date.
export const prerender = false;

const now = new Date();
const posts = (
  await getCollection('blog', ({ data }) => !data.draft && data.pubDate.getTime() <= now.getTime())
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatDate = (d: Date) =>
  d.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' });

const categories = [
  {
    id: 'carreras-pharma' as const,
    label: 'Carreras pharma',
    description:
      'Transición a industria farmacéutica LATAM: cómo se ve la realidad de las vacantes, los roles, los CVs y las entrevistas.',
  },
  {
    id: 'academia' as const,
    label: 'Academia → industria',
    description:
      'Cómo lo que aprendiste haciendo doctorado, papers o posgrado se traduce en valor real para un rol en pharma.',
  },
];

const postsByCategory = (catId: 'carreras-pharma' | 'academia') =>
  posts.filter((p) => p.data.category === catId);
---
<BaseLayout
  title="Blog Solca · Carreras en industria farmacéutica para profesionales en ciencias biológicas"
  description="Inteligencia de mercado, análisis de vacantes y guías para PhDs y profesionales en ciencias biológicas que quieren entrar a pharma LATAM. Publicado semanalmente."
>
  <!-- ==================== NAV ==================== -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <span class="dot"></span>
        <span>Solca</span>
      </a>
      <div class="nav-links">
        <a href="/blog" aria-current="page">Blog</a>
        <a href="/quiz-rol">Quiz</a>
        <a href="/revisar-cv">Revisar CV</a>
        <a href="/contacto">Contacto</a>
      </div>
    </div>
  </nav>

  <!-- ==================== HEADER ==================== -->
  <header class="blog-header">
    <div class="container">
      <div class="eyebrow">
        <span class="dot"></span>
        <span>Blog Solca</span>
      </div>
      <h1>Lo que el mercado pharma LATAM nos dice — y qué hacer con eso.</h1>
      <p class="blog-header-lead">
        Análisis de vacantes reales, guías de transición desde academia, y lecturas críticas del oficio en farma. Para profesionales en ciencias biológicas y afines que ya están listos para el siguiente paso.
      </p>
    </div>
  </header>

  <!-- ==================== POSTS GROUPED BY CATEGORY ==================== -->
  {categories.map((cat) => {
    const list = postsByCategory(cat.id);
    if (list.length === 0) return null;
    return (
      <section class="blog-section">
        <div class="container">
          <div class="blog-section-head">
            <h2 class="blog-section-title">{cat.label}</h2>
            <p class="blog-section-desc">{cat.description}</p>
          </div>
          <ul class="blog-grid">
            {list.map((post) => (
              <li class="blog-card">
                <a href={`/blog/${post.id}`}>
                  <div class="blog-card-image">
                    <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                  </div>
                  <div class="blog-card-body">
                    <div class="blog-card-meta">
                      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                      {post.data.series && post.data.seriesIndex && (
                        <span class="blog-card-series">· serie #{post.data.seriesIndex}</span>
                      )}
                    </div>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <span class="blog-card-cta">Leer →</span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    );
  })}

  <section class="blog-section blog-section-end">
    <div class="container">
      <a class="blog-rss" href="/rss.xml">⌁ Suscríbete vía RSS</a>
    </div>
  </section>

  <style is:global>
    .nav {
      position: sticky; top: 0; z-index: 50;
      background: rgba(250, 249, 244, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--rule);
    }
    .nav-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 14px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-brand {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 18px;
      color: var(--text);
      display: flex; align-items: center; gap: 10px;
    }
    .nav-links { display: flex; gap: 28px; }
    .nav-links a {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-mute);
    }
    .nav-links a:hover { color: var(--navy); opacity: 1; }
    .nav-links a[aria-current="page"] { color: var(--orange); }

    .blog-header {
      padding: 80px 0 48px;
      background: var(--bg);
    }
    .blog-header h1 {
      font-family: 'Inter', sans-serif;
      font-size: clamp(36px, 5vw, 60px);
      line-height: 1.05;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text);
      max-width: 880px;
      margin-bottom: 20px;
    }
    .blog-header-lead {
      font-size: 20px;
      line-height: 1.5;
      color: var(--text-mute);
      max-width: 760px;
    }

    .blog-section { padding: 56px 0; border-top: 1px solid var(--rule); }
    .blog-section-end { border-bottom: 1px solid var(--rule); }
    .blog-section-head { margin-bottom: 32px; max-width: 760px; }
    .blog-section-title {
      font-family: 'Inter', sans-serif;
      font-size: 32px;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 8px;
      letter-spacing: -0.015em;
    }
    .blog-section-desc {
      color: var(--text-mute);
      font-size: 17px;
      line-height: 1.55;
    }

    .blog-grid {
      list-style: none;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 28px;
    }
    .blog-card {
      background: white;
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .blog-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
    }
    .blog-card a {
      display: flex; flex-direction: column;
      color: inherit;
      height: 100%;
    }
    .blog-card-image { aspect-ratio: 16/9; overflow: hidden; background: var(--navy); }
    .blog-card-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .blog-card-body { padding: 22px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
    .blog-card-meta {
      font-size: 13px;
      color: var(--text-mute);
      font-family: 'Space Grotesk', sans-serif;
    }
    .blog-card-series { color: var(--orange); }
    .blog-card h3 {
      font-family: 'Inter', sans-serif;
      font-size: 21px;
      font-weight: 700;
      line-height: 1.25;
      color: var(--text);
      letter-spacing: -0.01em;
    }
    .blog-card p {
      font-size: 15px;
      line-height: 1.55;
      color: var(--text-mute);
      margin-bottom: 4px;
    }
    .blog-card-cta {
      margin-top: auto;
      font-size: 14px;
      color: var(--orange);
      font-weight: 600;
      font-family: 'Space Grotesk', sans-serif;
    }

    .blog-rss {
      font-size: 14px;
      color: var(--text-mute);
      font-family: 'Space Grotesk', sans-serif;
      letter-spacing: 0.05em;
    }
    .blog-rss:hover { color: var(--orange); opacity: 1; }
  </style>
</BaseLayout>
