---
// Redirect del QR impreso en "Día de Muertos Activity Book" (Solca Publishing).
//
// El libro es permanente; el destino puede cambiar. Si Brevo cambia la URL del
// formulario, sube de precio o desaparece, se edita SOLO esta constante y todos
// los libros ya impresos siguen funcionando.
//
// 302 (temporal) a propósito: un 301 lo cachea el navegador para siempre y nos
// quitaría la capacidad de cambiar el destino después.
//
// Excluida del sitemap (ver astro.config.mjs) y sin enlaces internos: esta ruta
// solo existe para el QR, no forma parte de Solca Ciencia.
//
// HISTORIAL DE DESTINOS:
//   jul 2026 — formulario de Brevo (captura de email antes de entregar el PDF)
//   jul 2026 — cuenta de Brevo cancelada: ahora va DIRECTO al PDF.
//              Los libros ya impresos siguen funcionando sin reimprimir nada:
//              esta es justamente la razón de haber usado dominio propio.

export const prerender = false;

const DESTINO = "https://solcaciencia.com/Solca-Publishing-Dia-de-Muertos-Mini-Guia.pdf";

return Astro.redirect(DESTINO, 302);
---
