  function pickRandomSurveyQuestions(): SurveyQuestion[] {
    // Always include core + 2 random from pool of 9
    const shuffled = [...SURVEY_POOL].sort(() => Math.random() - 0.5);
    return [SURVEY_CORE, shuffled[0], shuffled[1]];
  }

  function renderSurvey(): void {
    const surveyEl = document.getElementById('cv-survey');
    const questionsEl = document.getElementById('cv-survey-questions');
    if (!surveyEl || !questionsEl) return;

    const selected = pickRandomSurveyQuestions();
    questionsEl.innerHTML = '';
    selected.forEach((q) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'cv-survey-question';
      wrapper.dataset.qid = q.id;
      const optsHtml = q.options
        .map((opt) => `
          <label class="cv-survey-option">
            <input type="${q.type}" name="${q.id}" value="${opt.value}" />
            <span>${opt.label}</span>
          </label>
        `)
        .join('');
      wrapper.innerHTML = `
        <div class="cv-survey-question-text">${q.text}</div>
        <div class="cv-survey-options">${optsHtml}</div>
      `;
      questionsEl.appendChild(wrapper);
    });

    // Visual feedback on selection
    questionsEl.querySelectorAll('input').forEach((input) => {
      input.addEventListener('change', () => {
        const name = (input as HTMLInputElement).name;
        const isCheckbox = (input as HTMLInputElement).type === 'checkbox';
        if (!isCheckbox) {
          questionsEl
            .querySelectorAll(`input[name="${name}"]`)
            .forEach((el) => el.closest('label')?.classList.remove('cv-survey-option-checked'));
        }
        const lbl = input.closest('label');
        if (isCheckbox) {
          if ((input as HTMLInputElement).checked) lbl?.classList.add('cv-survey-option-checked');
          else lbl?.classList.remove('cv-survey-option-checked');
        } else {
          lbl?.classList.add('cv-survey-option-checked');
        }
      });
    });

    show(surveyEl);
    // Store exposed question IDs in dataset for submit
    surveyEl.dataset.exposed = selected.map((q) => q.id).join(',');
  }

  const surveyForm = document.getElementById('cv-survey-form') as HTMLFormElement | null;
  const surveySkip = document.getElementById('cv-survey-skip') as HTMLButtonElement | null;
  const surveySubmit = document.getElementById('cv-survey-submit') as HTMLButtonElement | null;

  surveyForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const surveyEl = document.getElementById('cv-survey');
    if (!surveyEl) return;
    const exposed = (surveyEl.dataset.exposed ?? '').split(',').filter(Boolean);
    const answers: Record<string, string | string[]> = {};
    exposed.forEach((qid) => {
      const inputs = surveyEl.querySelectorAll<HTMLInputElement>(`input[name="${qid}"]:checked`);
      if (inputs.length === 0) return;
      if (inputs[0].type === 'checkbox') {
        answers[qid] = Array.from(inputs).map((i) => i.value);
      } else {
        answers[qid] = inputs[0].value;
      }
    });
    if (Object.keys(answers).length === 0) {
      alert('Selecciona al menos una opción o usa "No, gracias".');
      return;
    }
    if (surveySubmit) {
      surveySubmit.disabled = true;
      surveySubmit.textContent = 'Enviando...';
    }
    try {
      await fetch('/api/cv-survey', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ exposed, answers }),
      });
    } catch (err) {
      console.warn('CV survey submit failed:', err);
    }
    // Hide form, show thanks
    const cardEl = document.getElementById('cv-survey-card');
    const thanksEl = document.getElementById('cv-survey-thanks');
    if (cardEl) cardEl.hidden = true;
    if (thanksEl) thanksEl.hidden = false;
  });

  surveySkip?.addEventListener('click', () => {
    const surveyEl = document.getElementById('cv-survey');
    if (surveyEl) surveyEl.hidden = true;
  });

  // Hook: invoke renderSurvey when result is shown
  const _origShow = show;
  function showWithSurveyHook(el: HTMLElement | null) {
    _origShow(el);
    if (el && el.id === 'result') {
      // Small delay so UX feels natural (analysis settles first)
      setTimeout(() => renderSurvey(), 800);
    }
  }
  // Replace internal `show(result)` invocations is impractical; instead,
  // observe the result element becoming visible.
  if (result) {
    const observer = new MutationObserver(() => {
      if (!result.hidden && document.getElementById('cv-survey')?.hidden) {
        setTimeout(() => renderSurvey(), 800);
      }
    });
    observer.observe(result, { attributes: true, attributeFilter: ['hidden'] });
  }

  // ============ Share strip · LinkedIn / WhatsApp / Email / Copy ============
  document.querySelectorAll<HTMLButtonElement>('.share-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const strip = btn.closest<HTMLElement>('.share-strip');
      if (!strip) return;
      const shareUrl = strip.dataset.shareUrl || window.location.href;
      const shareText = strip.dataset.shareText || '';
      const fullText = shareText ? `${shareText} ${shareUrl}` : shareUrl;
      const target = btn.dataset.share;

      let openUrl = '';
      if (target === 'linkedin') {
        openUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`;
      } else if (target === 'whatsapp') {
        openUrl = `https://wa.me/?text=${encodeURIComponent(fullText)}`;
      } else if (target === 'email') {
        const subject = encodeURIComponent('Te recomiendo esto · Solca');
        const body = encodeURIComponent(fullText);
        openUrl = `mailto:?subject=${subject}&body=${body}`;
      } else if (target === 'copy') {
        try {
          await navigator.clipboard.writeText(fullText);
          btn.classList.add('share-btn-copied');
          setTimeout(() => btn.classList.remove('share-btn-copied'), 1500);
        } catch (err) {
          console.warn('clipboard failed', err);
          const ta = document.createElement('textarea');
          ta.value = fullText;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          btn.classList.add('share-btn-copied');
          setTimeout(() => btn.classList.remove('share-btn-copied'), 1500);
        }
        return;
      }
      if (openUrl) {
        window.open(openUrl, '_blank', 'noopener,noreferrer');
      }
    });
  });
</script>

</BaseLayout>
