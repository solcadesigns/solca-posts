</style>

<script>
  const form = document.getElementById('cv-form') as HTMLFormElement | null;
  const loading = document.getElementById('loading') as HTMLElement | null;
  const loadingStatus = document.getElementById('loading-status') as HTMLElement | null;
  const result = document.getElementById('result') as HTMLElement | null;
  const errorSection = document.getElementById('error') as HTMLElement | null;
  const errorMessage = document.getElementById('error-message') as HTMLElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement | null;
  const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement | null;
  const errorRetryBtn = document.getElementById('error-retry-btn') as HTMLButtonElement | null;
  const cvTextarea = document.getElementById('cv') as HTMLTextAreaElement | null;
  const cvUpload = document.getElementById('cv-upload') as HTMLInputElement | null;
  const uploadStatus = document.getElementById('upload-status') as HTMLElement | null;
  const textareaWrapper = document.getElementById('textarea-wrapper') as HTMLElement | null;
  const textareaCollapsed = document.getElementById('textarea-collapsed') as HTMLElement | null;
  const toggleTextareaBtn = document.getElementById('toggle-textarea') as HTMLButtonElement | null;
  const pdfWarning = document.getElementById('pdf-warning') as HTMLElement | null;

  function hide(el: HTMLElement | null) { if (el) el.hidden = true; }
  function show(el: HTMLElement | null) { if (el) el.hidden = false; }

  // ---- PDF upload: lazy-load pdf.js from CDN, extract text, fill textarea ----
  let pdfjsPromise: Promise<any> | null = null;
  async function loadPdfJs() {
    if (!pdfjsPromise) {
      pdfjsPromise = (async () => {
        const lib = await import(
          /* @vite-ignore */ 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.10.38/build/pdf.min.mjs'
        );
        lib.GlobalWorkerOptions.workerSrc =
          'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.10.38/build/pdf.worker.min.mjs';
        return lib;
      })();
    }
    return pdfjsPromise;
  }

  function setUploadStatus(text: string, kind: 'idle' | 'success' | 'error' = 'idle') {
    if (!uploadStatus) return;
    uploadStatus.textContent = text;
    uploadStatus.classList.remove('success', 'error');
    if (kind !== 'idle') uploadStatus.classList.add(kind);
  }

  cvUpload?.addEventListener('change', async (e) => {
    const target = e.target as HTMLInputElement;
    const file = target.files?.[0];

    // Usuario quitó el archivo (clicó la ✕) → resetear estado: mostrar textarea, limpiar status y aviso.
    if (!file) {
      setUploadStatus('', 'idle');
      hide(pdfWarning);
      hide(textareaCollapsed);
      show(textareaWrapper);
      if (cvTextarea) cvTextarea.value = '';
      return;
    }

    // Reset previous warning state
    hide(pdfWarning);

    if (file.type !== 'application/pdf' && !file.name.toLowerCase().endsWith('.pdf')) {
      setUploadStatus('Solo PDFs. Para otros formatos, pega el texto.', 'error');
      target.value = '';
      return;
    }
    if (file.size > 10 * 1024 * 1024) {
      setUploadStatus('PDF excede 10 MB. Reduce el archivo o pega el texto.', 'error');
      target.value = '';
      return;
    }

    setUploadStatus('Procesando PDF...', 'idle');

    try {
      const pdfjsLib = await loadPdfJs();
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      let fullText = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        const pageText = content.items
          .map((item: { str?: string }) => item.str ?? '')
          .join(' ')
          .replace(/\s+/g, ' ')
          .trim();
        fullText += pageText + '\n\n';
      }
      fullText = fullText.trim();
      if (cvTextarea) {
        cvTextarea.value = fullText;
      }
      if (fullText.length < 200) {
        setUploadStatus(
          `Solo se extrajeron ${fullText.length} caracteres.`,
          'error',
        );
        // Mostrar aviso educativo de ATS
        show(pdfWarning);
        // Mantener textarea visible para que el usuario pegue manualmente
        show(textareaWrapper);
        hide(textareaCollapsed);
      } else {
        setUploadStatus(
          `✓ PDF cargado · ${pdf.numPages} ${pdf.numPages === 1 ? 'página' : 'páginas'} · ${fullText.length.toLocaleString('es-MX')} caracteres extraídos`,
          'success',
        );
        // Éxito: ocultar textarea + ocultar botón "Ver/editar" + ocultar aviso.
        // El usuario confía en el status ✓; si el extract resultara malo, puede quitar el archivo
        // y pegar el texto manualmente.
        hide(textareaWrapper);
        hide(textareaCollapsed);
        hide(pdfWarning);
      }
    } catch (err) {
      console.error('PDF parse error:', err);
      setUploadStatus('No pudimos leer el PDF.', 'error');
      // Mostrar aviso educativo de ATS
      show(pdfWarning);
      show(textareaWrapper);
      hide(textareaCollapsed);
    }
  });

  toggleTextareaBtn?.addEventListener('click', () => {
    show(textareaWrapper);
    hide(textareaCollapsed);
    cvTextarea?.focus();
  });

  function setStatusCycling() {
    if (!loadingStatus) return null;
    const messages = [
      'Leyendo estructura y experiencias.',
      'Evaluando coherencia y posicionamiento.',
      'Buscando palabras clave de industria.',
      'Revisando métricas y verbos activos.',
      'Verificando compatibilidad ATS.',
      'Sintetizando observaciones.',
    ];
    let i = 0;
    const interval = window.setInterval(() => {
      i = (i + 1) % messages.length;
      if (loadingStatus) loadingStatus.textContent = messages[i] ?? '';
    }, 3500);
    return interval;
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  interface Observacion { categoria: string; evaluacion: string; recomendacion: string; }
  interface Result { candidateName: string; retroalimentacion: string; observaciones: Observacion[]; }

  // Guardamos el último análisis para que el botón de descarga lo use
  let lastResult: Result | null = null;

  function renderResult(data: Result) {
    lastResult = data;
    const titleEl = document.getElementById('result-title');
    const retroEl = document.getElementById('result-retroalimentacion');
    const obsList = document.getElementById('result-observaciones-list');
    if (titleEl) titleEl.textContent = `Análisis básico para ${data.candidateName}`;
    if (retroEl) retroEl.textContent = data.retroalimentacion;
    if (obsList) {
      obsList.innerHTML = data.observaciones
        .map(
          (o) => `<li>
  <span class="obs-cat">${escapeHtml(o.categoria)}</span>
  <p class="obs-eval">${escapeHtml(o.evaluacion)}</p>
  <p class="obs-rec">→ ${escapeHtml(o.recomendacion)}</p>
</li>`,
        )
        .join('');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const fd = new FormData(form);
    const payload = {
      cv: String(fd.get('cv') ?? '').trim(),
      email: String(fd.get('email') ?? '').trim(),
      country: String(fd.get('country') ?? ''),
      consent: fd.get('consent') === 'on',
    };

    // Quick client-side validation
    if (!payload.consent) {
      alert('Debes aceptar la política de datos antes de continuar.');
      return;
    }
    if (payload.cv.length < 200) {
      alert('El CV es muy corto. Pega el texto completo (mínimo 200 caracteres).');
      return;
    }

    // Switch to loading
    hide(form.parentElement?.parentElement ?? null);
    hide(errorSection);
    show(loading);
    submitBtn && (submitBtn.disabled = true);
    const intervalId = setStatusCycling();

    try {
      const res = await fetch('/api/cv-review', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (intervalId) window.clearInterval(intervalId);

      if (!res.ok) {
        const errBody = await res.json().catch(() => ({ message: 'Error desconocido' }));
        throw new Error(errBody.message || `HTTP ${res.status}`);
      }

      const data = (await res.json()) as Result;
      renderResult(data);
      hide(loading);
      show(result);
      // Scroll to top of result
      window.scrollTo({ top: result?.offsetTop ?? 0, behavior: 'smooth' });
    } catch (err) {
      if (intervalId) window.clearInterval(intervalId);
      hide(loading);
      const msg = err instanceof Error ? err.message : 'Error desconocido.';
      if (errorMessage) errorMessage.textContent = msg;
      show(errorSection);
      submitBtn && (submitBtn.disabled = false);
    }
  });

  // ---- PDF generation con jsPDF directo (texto nativo, no imagen) ----
  let jsPdfPromise: Promise<any> | null = null;
  function loadJsPdf(): Promise<any> {
    if (!jsPdfPromise) {
      jsPdfPromise = new Promise((resolve, reject) => {
        const w = window as any;
        if (w.jspdf?.jsPDF) { resolve(w.jspdf.jsPDF); return; }
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/jspdf@2.5.2/dist/jspdf.umd.min.js';
        script.async = true;
        script.onload = () => {
          if (w.jspdf?.jsPDF) resolve(w.jspdf.jsPDF);
          else reject(new Error('jsPDF no se cargó correctamente'));
        };
        script.onerror = () => reject(new Error('No pudimos cargar la librería de PDF'));
        document.head.appendChild(script);
      });
    }
    return jsPdfPromise;
  }

  // Sanitiza texto para evitar caracteres no soportados por Helvetica (default font de jsPDF).
  // jsPDF + Helvetica solo cubren WinAnsi. Caracteres Unicode fuera de ese set rompen el
  // cálculo de ancho de splitTextToSize y el render se va off-page o se ve con letter spacing raro.
  function sanitizeForPDF(text: string): string {
    if (!text) return '';
    return text
      .replace(/→/g, '>')           // right arrow → ASCII greater-than
      .replace(/←/g, '<')
      .replace(/↑/g, '^')
      .replace(/↓/g, 'v')
      .replace(/—/g, ' - ')         // em dash
      .replace(/–/g, '-')           // en dash
      .replace(/[‘’‚‛]/g, "'")  // curly single quotes
      .replace(/[“”„‟]/g, '"')  // curly double quotes
      .replace(/…/g, '...')
      .replace(/•/g, '*')
      .replace(/✓/g, 'OK')
      .replace(/✗/g, 'X')
      .replace(/[‐-―]/g, '-')   // various dashes
      .replace(/[  ]/g, ' ')    // non-breaking spaces
      .replace(/[​‌‍﻿]/g, ''); // zero-width spaces / BOM
  }

  function generatePdf(JsPDF: any, data: Result): any {
    const doc = new JsPDF({ unit: 'mm', format: 'a4', orientation: 'portrait' });

    // Sanitiza el contenido completo antes de procesar
    const safeData: Result = {
      candidateName: sanitizeForPDF(data.candidateName),
      retroalimentacion: sanitizeForPDF(data.retroalimentacion),
      observaciones: data.observaciones.map((o) => ({
        categoria: sanitizeForPDF(o.categoria),
        evaluacion: sanitizeForPDF(o.evaluacion),
        recomendacion: sanitizeForPDF(o.recomendacion),
      })),
    };

    // Page constants (mm)
    const PAGE_W = 210;
    const PAGE_H = 297;
    const M_X = 18;
    const M_TOP = 18;
    const M_BOTTOM = 22;
    const C_W = PAGE_W - 2 * M_X;

    // Brand colors (RGB tuples)
    const NAVY: [number, number, number] = [27, 58, 107];
    const NAVY_DEEP: [number, number, number] = [15, 39, 72];
    const ORANGE: [number, number, number] = [232, 116, 58];
    const OFFW: [number, number, number] = [247, 245, 238];
    const TEXT: [number, number, number] = [27, 37, 64];
    const TEXTMUTE: [number, number, number] = [90, 100, 128];
    const RULE: [number, number, number] = [220, 218, 210];

    let y = M_TOP;

    function setColor(setter: 'fill' | 'stroke' | 'text', color: [number, number, number]) {
      if (setter === 'fill') doc.setFillColor(color[0], color[1], color[2]);
      else if (setter === 'stroke') doc.setDrawColor(color[0], color[1], color[2]);
      else doc.setTextColor(color[0], color[1], color[2]);
    }

    function needBreak(spaceNeeded: number) {
      if (y + spaceNeeded > PAGE_H - M_BOTTOM) {
        doc.addPage();
        y = M_TOP;
      }
    }

    function drawFooter(pageNum: number, totalPages: number) {
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(8);
      setColor('text', TEXTMUTE);
      doc.text('Solca · Ciencia y Consultoría · hello@solcaciencia.com', M_X, PAGE_H - 10);
      doc.text(`Página ${pageNum} / ${totalPages}`, PAGE_W - M_X, PAGE_H - 10, { align: 'right' });
    }

    // ===== HEADER (solo en página 1) =====
    // Logo: navy rounded square + naranja dot + thin orange ring
    setColor('fill', NAVY_DEEP);
    doc.roundedRect(M_X, y, 10, 10, 1.8, 1.8, 'F');
    setColor('fill', ORANGE);
    doc.circle(M_X + 5, y + 5, 1.5, 'F');
    setColor('stroke', ORANGE);
    doc.setLineWidth(0.35);
    doc.circle(M_X + 5, y + 5, 3, 'S');

    // Brand text
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(14);
    setColor('text', NAVY);
    doc.text('Solca', M_X + 13.5, y + 4.5);

    doc.setFont('helvetica', 'normal');
    doc.setFontSize(7.5);
    setColor('text', ORANGE);
    doc.text('CIENCIA Y CONSULTORÍA', M_X + 13.5, y + 9);

    // Email right-aligned
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(9);
    setColor('text', TEXTMUTE);
    doc.text('hello@solcaciencia.com', PAGE_W - M_X, y + 7, { align: 'right' });

    y += 13;

    // Header divider
    setColor('stroke', RULE);
    doc.setLineWidth(0.4);
    doc.line(M_X, y, PAGE_W - M_X, y);

    y += 11;

    // ===== TITLE =====
    // Eyebrow dot + text
    setColor('fill', ORANGE);
    doc.circle(M_X + 1.5, y - 1.5, 1, 'F');
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(8);
    setColor('text', ORANGE);
    doc.text('ANÁLISIS BÁSICO DE CV', M_X + 5, y);

    y += 8;

    // Title h1
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(22);
    setColor('text', NAVY);
    const titleText = `Análisis básico para ${safeData.candidateName}`;
    const titleLines = doc.splitTextToSize(titleText, C_W);
    titleLines.forEach((line: string, i: number) => {
      doc.text(line, M_X, y + i * 9);
    });
    y += titleLines.length * 9 + 6;

    // ===== RETROALIMENTACIÓN =====
    // Section header with orange underline
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(14);
    setColor('text', NAVY);
    doc.text('Retroalimentación', M_X, y);
    setColor('stroke', ORANGE);
    doc.setLineWidth(0.8);
    const retroTw = doc.getTextWidth('Retroalimentación');
    doc.line(M_X, y + 1.5, M_X + retroTw, y + 1.5);
    y += 9;

    // Body
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10.5);
    setColor('text', TEXT);
    const retroLines = doc.splitTextToSize(safeData.retroalimentacion, C_W);
    retroLines.forEach((line: string) => {
      needBreak(5);
      doc.text(line, M_X, y);
      y += 5;
    });
    y += 6;

    // ===== OBSERVACIONES =====
    needBreak(15);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(14);
    setColor('text', NAVY);
    doc.text('Observaciones puntuales y recomendaciones', M_X, y);
    setColor('stroke', ORANGE);
    doc.setLineWidth(0.8);
    const obsTw = doc.getTextWidth('Observaciones puntuales y recomendaciones');
    doc.line(M_X, y + 1.5, M_X + obsTw, y + 1.5);
    y += 9;

    // Render each observación
    safeData.observaciones.forEach((obs, idx) => {
      // Estimate height needed for this whole obs (cat + body + rec)
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(11);
      const catLines = doc.splitTextToSize(`${obs.categoria}:`, C_W);
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(10);
      const evalLines = doc.splitTextToSize(obs.evaluacion, C_W);
      doc.setFontSize(9.5);
      const recLines = doc.splitTextToSize(obs.recomendacion, C_W - 5);
      const totalHeight = catLines.length * 5.5 + evalLines.length * 4.8 + recLines.length * 4.6 + 8;
      needBreak(totalHeight);

      // Category (bold, navy)
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(11);
      setColor('text', NAVY);
      catLines.forEach((line: string, i: number) => {
        doc.text(line, M_X, y + i * 5.5);
      });
      y += catLines.length * 5.5 + 1;

      // Evaluation (regular, text color)
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(10);
      setColor('text', TEXT);
      evalLines.forEach((line: string) => {
        doc.text(line, M_X, y);
        y += 4.8;
      });
      y += 1;

      // Recommendation (smaller, muted, with orange left bar)
      const recStartY = y;
      setColor('text', TEXTMUTE);
      doc.setFontSize(9.5);
      recLines.forEach((line: string) => {
        doc.text(line, M_X + 5, y);
        y += 4.6;
      });
      // Orange left border
      setColor('stroke', ORANGE);
      doc.setLineWidth(0.8);
      doc.line(M_X + 2, recStartY - 3, M_X + 2, y - 2);

      // Spacing between observations
      if (idx < safeData.observaciones.length - 1) {
        y += 5;
        // Subtle divider
        setColor('stroke', RULE);
        doc.setLineWidth(0.2);
        doc.line(M_X, y, PAGE_W - M_X, y);
        y += 4;
      } else {
        y += 8;
      }
    });

    // ===== SIGUIENTE PASO (CTA navy box) =====
    const ctaBodyText =
      'Si quieres mejorar tu CV de forma estructurada y aprender a posicionarlo correctamente para procesos reales de selección, revisa el curso completo donde explico cómo redactar un CV, optimizar LinkedIn y aplicar estratégicamente.';
    const ctaNoteText = 'Los ejemplos están enfocados en ciencias biológicas y de la salud — los conceptos aplican a cualquier área.';
    const ctaLinkText = 'Ver el curso en Hotmart';
    const ctaLinkURL = 'https://go.hotmart.com/B104495115T';
    const ctaSignName = 'Oscar Solís';
    const ctaSignTitle = 'Director general, Solca Ciencia y Consultoría';

    // Calculate box height
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10);
    const ctaBodyLines = doc.splitTextToSize(ctaBodyText, C_W - 12);
    doc.setFontSize(9);
    const ctaNoteLines = doc.splitTextToSize(ctaNoteText, C_W - 12);
    const boxPadding = 6;
    const boxHeight =
      boxPadding * 2 +
      9 + // header
      ctaBodyLines.length * 5 + 3 +
      ctaNoteLines.length * 4.5 + 5 +
      8 + // link
      10; // signature
    needBreak(boxHeight + 5);

    const boxStartY = y;
    setColor('fill', NAVY_DEEP);
    doc.roundedRect(M_X, boxStartY, C_W, boxHeight, 2.5, 2.5, 'F');

    let cy = boxStartY + boxPadding;
    // Section header inside box
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(13);
    setColor('text', OFFW);
    doc.text('Siguiente paso sugerido', M_X + boxPadding, cy + 2);
    setColor('stroke', ORANGE);
    doc.setLineWidth(0.7);
    const cthtw = doc.getTextWidth('Siguiente paso sugerido');
    doc.line(M_X + boxPadding, cy + 3.5, M_X + boxPadding + cthtw, cy + 3.5);
    cy += 9;

    // Body
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10);
    setColor('text', OFFW);
    ctaBodyLines.forEach((line: string) => {
      doc.text(line, M_X + boxPadding, cy);
      cy += 5;
    });
    cy += 1;

    // Note in italic
    doc.setFont('helvetica', 'italic');
    doc.setFontSize(9);
    setColor('text', [200, 198, 188]);
    ctaNoteLines.forEach((line: string) => {
      doc.text(line, M_X + boxPadding, cy);
      cy += 4.5;
    });
    cy += 3;

    // Link (link-like text — clickable in jsPDF via doc.link)
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(10);
    setColor('text', ORANGE);
    doc.textWithLink(`>> ${ctaLinkText}`, M_X + boxPadding, cy + 1, { url: ctaLinkURL });
    cy += 8;

    // Signature inside box (lighter)
    setColor('stroke', [60, 70, 95]);
    doc.setLineWidth(0.3);
    doc.line(M_X + boxPadding, cy, PAGE_W - M_X - boxPadding, cy);
    cy += 4;

    doc.setFont('helvetica', 'bold');
    doc.setFontSize(9.5);
    setColor('text', OFFW);
    doc.text(`— ${ctaSignName}`, M_X + boxPadding, cy);
    doc.setFont('helvetica', 'italic');
    doc.setFontSize(8.5);
    setColor('text', [200, 198, 188]);
    doc.text(ctaSignTitle, M_X + boxPadding, cy + 4);

    y = boxStartY + boxHeight + 6;

    // ===== FOOTERS on all pages =====
    const totalPages = doc.internal.pages.length - 1;
    for (let i = 1; i <= totalPages; i++) {
      doc.setPage(i);
      drawFooter(i, totalPages);
    }

    return doc;
  }

  downloadBtn?.addEventListener('click', async () => {
    if (!downloadBtn || !lastResult) return;
    const originalText = downloadBtn.innerHTML;
    downloadBtn.disabled = true;
    downloadBtn.innerHTML =
      '<span style="display:inline-block; width:18px; height:18px; border:2.5px solid currentColor; border-top-color: transparent; border-radius:50%; animation: spin 0.9s linear infinite;"></span> Generando PDF…';
    try {
      const JsPDF = await loadJsPdf();
      const doc = generatePdf(JsPDF, lastResult);
      const date = new Date().toISOString().slice(0, 10);
      const safeName = lastResult.candidateName.replace(/[^a-zA-Z0-9áéíóúñÁÉÍÓÚÑ -]/g, '').trim().replace(/\s+/g, '-');
      const filename = `Analisis-Solca-${safeName}-${date}.pdf`;
      doc.save(filename);
    } catch (err) {
      console.error('Download PDF error', err);
      alert('No pudimos generar el PDF. Intenta de nuevo, o reporta el problema en /contacto.');
    } finally {
      downloadBtn.disabled = false;
      downloadBtn.innerHTML = originalText;
    }
  });

