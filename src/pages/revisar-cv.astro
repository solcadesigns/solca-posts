---
import BaseLayout from '../layouts/BaseLayout.astro';

const cursoURL = 'https://go.hotmart.com/B104495115T';
const newsletterURL =
  'https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7432492458158120960';
const atsBlogURL =
  'https://www.linkedin.com/pulse/por-qu%C3%A9-tu-cv-pasa-filtros-ats-oscar-solis-ciencia-y-consultoria--xxlce/';
---
<BaseLayout
  title="Análisis gratis de tu CV · Solca"
  description="Recibe feedback estructurado contra 20 criterios de selección en industria farmacéutica. Coherencia, métricas, palabras clave, compatibilidad ATS, posicionamiento. Gratis, sin pago, sin compromiso."
>

<!-- ==================== NAV ==================== -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <span class="dot"></span>
      <span>Solca</span>
    </a>
    <div class="nav-links">
      <a href="/#libros">Libros</a>
      <a href="/#curso">Curso</a>
      <a href="/revisar-cv">Revisar CV</a>
      <a href="/#sobre">Sobre</a>
      <a href="/contacto">Contacto</a>
    </div>
  </div>
</nav>

<!-- ==================== HERO ==================== -->
<section class="cv-hero">
  <div class="diagonals"></div>
  <div class="container cv-hero-inner">
    <div class="eyebrow">
      <span class="dot"></span>
      <span>Recurso gratuito</span>
    </div>
    <h1 class="cv-hero-title">Análisis profesional de tu CV en <em>30 segundos</em></h1>
    <p class="cv-hero-lead">
      Pega tu CV y recibe feedback estructurado contra 20 criterios reales de selección en industria farmacéutica: coherencia, métricas, palabras clave, compatibilidad ATS, posicionamiento profesional. Sin pago, sin compromiso.
    </p>
    <div class="cv-hero-meta">
      <span class="meta-item"><span class="meta-dot"></span>Análisis cualitativo</span>
      <span class="meta-item"><span class="meta-dot"></span>20 categorías evaluadas</span>
      <span class="meta-item"><span class="meta-dot"></span>Recomendaciones accionables</span>
    </div>
  </div>
</section>

<!-- ==================== FORM ==================== -->
<section class="cv-form-section" id="form">
  <div class="container">
    <form id="cv-form" class="cv-form" novalidate>
      <div class="cv-form-grid">
        <div class="field full">
          <label for="cv-upload">Sube tu CV como PDF <span class="optional-label">(o pega el texto abajo)</span></label>
          <div class="upload-wrap">
            <input type="file" id="cv-upload" accept="application/pdf,.pdf" />
            <span id="upload-status" class="upload-status"></span>
          </div>
          <p class="field-help" style="margin-bottom: 14px;">
            El PDF se procesa localmente en tu navegador. No se sube a nuestro servidor.
          </p>

          <!-- Aviso · PDF no legible · también pista sobre ATS · oculto por default -->
          <aside class="pdf-warning" id="pdf-warning" hidden>
            <div class="pdf-warning-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
            </div>
            <div class="pdf-warning-content">
              <h4>Tu PDF no se pudo leer</h4>
              <p>
                Esto suele significar que el PDF tiene el texto como imagen (escaneado), usa una fuente que los parsers no entienden, o tiene un layout complejo (columnas, gráficos, íconos).
              </p>
              <p class="pdf-warning-callout">
                <strong>Importante:</strong> los sistemas ATS de selección de pharma usan parsers similares a este. Si tu PDF no se pudo leer aquí, <strong>probablemente tampoco pasará el primer filtro automático</strong> de las plataformas de aplicación a las que envíes el CV.
              </p>
              <p class="pdf-warning-actions-label">Antes de seguir, vale la pena leer:</p>
              <ul class="pdf-warning-actions">
                <li>
                  <a href={atsBlogURL} target="_blank" rel="noopener">
                    → Por qué tu CV no pasa filtros ATS (artículo)
                  </a>
                </li>
                <li>
                  <a href={newsletterURL} target="_blank" rel="noopener">
                    → Suscribirte al newsletter Solca Insight en LinkedIn
                  </a>
                </li>
              </ul>
              <p class="pdf-warning-fallback">
                Mientras decides cómo arreglar tu CV, puedes pegar el texto abajo y recibir el análisis de la versión actual.
              </p>
            </div>
          </aside>

          <!-- Vista colapsada cuando PDF se subió OK · oculto por default -->
          <div class="textarea-collapsed" id="textarea-collapsed" hidden>
            <button type="button" id="toggle-textarea" class="textarea-toggle-btn">
              Ver / editar texto extraído
            </button>
          </div>

          <!-- Vista expandida (default cuando no se ha subido PDF) -->
          <div class="textarea-wrapper" id="textarea-wrapper">
            <label for="cv">Texto del CV</label>
            <textarea
              id="cv"
              name="cv"
              rows="14"
              placeholder="Pega aquí el texto de tu CV: selecciona todo en tu Word/Pages (Cmd+A), copia (Cmd+C) y pega (Cmd+V). O sube el PDF arriba y procesamos el texto automáticamente."
              required
              minlength="200"
              maxlength="15000"
              aria-describedby="cv-help"
            ></textarea>
            <p id="cv-help" class="field-help">
              Mínimo 200 caracteres. Máximo 15,000.
            </p>
          </div>
        </div>

        <div class="field">
          <label for="email">Tu email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="tu@email.com"
            required
            autocomplete="email"
          />
        </div>

        <div class="field">
          <label for="country">País (opcional)</label>
          <select id="country" name="country">
            <option value="">Selecciona</option>
            <option value="México">México</option>
            <option value="Brasil">Brasil</option>
            <option value="Argentina">Argentina</option>
            <option value="Colombia">Colombia</option>
            <option value="Chile">Chile</option>
            <option value="España">España</option>
            <option value="Perú">Perú</option>
            <option value="Ecuador">Ecuador</option>
            <option value="Otro LATAM">Otro LATAM</option>
            <option value="Otro">Otro</option>
          </select>
        </div>

        <div class="field full consent-field">
          <label class="consent-label">
            <input type="checkbox" id="consent" name="consent" required />
            <span>
              Acepto que el texto de mi CV se procese con IA bajo la rúbrica de Oscar Solís para generar el análisis. <strong>El contenido del CV NO se guarda en nuestros servidores</strong> — se procesa en memoria, se genera el feedback y se descarta. Mi email se guarda para enviarme contenido relevante; puedo darme de baja cuando quiera. Consulta el <a href="/privacidad" target="_blank" rel="noopener">aviso de privacidad</a>.
            </span>
          </label>
        </div>

        <div class="field full">
          <button type="submit" id="submit-btn" class="btn btn-orange btn-large btn-block">
            Recibir mi análisis
          </button>
        </div>
      </div>
    </form>
  </div>
</section>

<!-- ==================== LOADING ==================== -->
<section class="cv-loading" id="loading" hidden>
  <div class="container">
    <div class="loading-card">
      <div class="spinner" aria-hidden="true"></div>
      <h2>Analizando tu CV…</h2>
      <p id="loading-status">Leyendo estructura y experiencias.</p>
      <p class="loading-fineprint">Esto toma 15-30 segundos. No cierres ni recargues esta pestaña.</p>
    </div>
  </div>
</section>

<!-- ==================== RESULT ==================== -->
<section class="cv-result" id="result" hidden>
  <div class="container">
    <!-- Brand header (aparece arriba del resultado y se imprime en PDF) -->
    <div class="result-brand-header">
      <a href="/" class="result-brand-mark">
        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="32" height="32" rx="6" fill="#0F2748"/>
          <circle cx="16" cy="16" r="5" fill="#E8743A"/>
          <circle cx="16" cy="16" r="9" fill="none" stroke="#E8743A" stroke-width="1.4" opacity="0.45"/>
        </svg>
        <span class="result-brand-text">
          <span class="result-brand-name">Solca</span>
          <span class="result-brand-tag">Ciencia y Consultoría</span>
        </span>
      </a>
      <div class="result-brand-meta">
        <a href="mailto:hello@solcaciencia.com">hello@solcaciencia.com</a>
      </div>
    </div>

    <!-- Notice arriba: indica que el PDF está al final -->
    <div class="result-download-notice">
      <span class="result-download-notice-icon" aria-hidden="true">↓</span>
      <span>
        El PDF descargable está al final del análisis, junto al <strong>siguiente paso recomendado</strong>.
      </span>
    </div>

    <header class="result-header">
      <div class="eyebrow">
        <span class="dot"></span>
        <span>Análisis básico de CV</span>
      </div>
      <h2 id="result-title">Análisis básico para [nombre]</h2>
    </header>

    <article class="result-feedback">
      <h3>Retroalimentación</h3>
      <p id="result-retroalimentacion"></p>
    </article>

    <article class="result-observaciones">
      <h3>Observaciones puntuales y recomendaciones</h3>
      <ul id="result-observaciones-list"></ul>
    </article>

    <article class="result-cta">
      <h3>Siguiente paso sugerido</h3>
      <p>
        Si quieres mejorar tu CV de forma estructurada y aprender a posicionarlo correctamente para procesos reales de selección, revisa el curso completo donde explico cómo redactar un CV, optimizar LinkedIn y aplicar estratégicamente.
      </p>
      <p class="result-cta-note">
        Los ejemplos están enfocados en ciencias biológicas y de la salud — los conceptos aplican a cualquier área.
      </p>
      <a href={cursoURL} class="btn btn-orange btn-large" target="_blank" rel="noopener">
        Ver el curso en Hotmart
      </a>
      <p class="result-sign">
        — Oscar Solís · <em>Director general, Solca Ciencia y Consultoría</em>
      </p>
    </article>

    <!-- ==================== POST-RESULT SURVEY (anónima, opcional) ==================== -->
    <div class="cv-survey" id="cv-survey" hidden>
      <div class="cv-survey-card" id="cv-survey-card">
        <h3 class="cv-survey-title">Ya puedes descargar tu análisis abajo. ¿Me ayudas con 3 preguntas a cambio?</h3>
        <p class="cv-survey-helper">
          Toma ~30 segundos. Respuestas anónimas — no las vinculamos a tu email ni a tu CV. Alimentan el reporte gratuito <em>State of PhD Transition LATAM</em> que publicaré en 2027.
        </p>
        <form id="cv-survey-form">
          <div id="cv-survey-questions"></div>
          <div class="cv-survey-actions">
            <button type="submit" class="btn btn-orange" id="cv-survey-submit">Enviar respuestas</button>
            <button type="button" class="btn-skip" id="cv-survey-skip">No, gracias</button>
          </div>
        </form>
      </div>
      <div class="cv-survey-thanks" id="cv-survey-thanks" hidden>
        <p><strong>Gracias.</strong> Apreciamos tu tiempo.</p>
      </div>
    </div>

    <div class="result-actions">
      <button type="button" id="download-btn" class="btn btn-orange btn-large">
        <span class="download-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
        </span>
        Descargar PDF
      </button>
      <button type="button" id="retry-btn" class="btn btn-secondary" style="color: var(--navy); border-color: var(--navy);">
        Revisar otro CV
      </button>
    </div>

    <div class="share-strip"
         data-share-url="https://solcaciencia.com/revisar-cv"
         data-share-text="Probé esta app gratuita que analiza tu CV con IA y marca los errores típicos de PhDs aplicando a pharma. Toma 60 segundos.">
      <span class="share-strip-label">Compartir esta herramienta</span>
      <div class="share-strip-buttons">
        <button type="button" class="share-btn" data-share="linkedin" aria-label="Compartir en LinkedIn" title="LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zM8.34 17.34V10.5H6.17v6.84zM7.25 9.5a1.26 1.26 0 1 0 0-2.51 1.26 1.26 0 0 0 0 2.51zM18 17.34v-3.75c0-2-1.07-2.93-2.5-2.93a2.16 2.16 0 0 0-1.95 1.08v-.93h-2.16c.03.61 0 6.53 0 6.53h2.16v-3.82a1.48 1.48 0 0 1 .07-.53 1.18 1.18 0 0 1 1.11-.79c.78 0 1.1.6 1.1 1.47v3.67z"/></svg>
        </button>
        <button type="button" class="share-btn" data-share="whatsapp" aria-label="Compartir por WhatsApp" title="WhatsApp">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1l-.9 1.2c-.2.2-.4.2-.7.1-1-.4-1.9-1-2.7-1.7-.7-.7-1.3-1.5-1.8-2.4-.1-.2 0-.5.1-.6.1-.1.2-.3.4-.4.1-.1.2-.3.3-.4.1-.1.1-.3 0-.4-.1-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.7.4-.7.7-1.1 1.6-1.1 2.6.1 1.2.5 2.3 1.2 3.3 1.3 1.9 3 3.4 5 4.4.6.3 1 .4 1.4.5.6.2 1.1.2 1.6.1.5-.1 1.6-.7 1.8-1.3.2-.5.2-1 .2-1.1zM12 22a10 10 0 0 1-5.3-1.5L2 22l1.5-4.6A10 10 0 0 1 2 12 10 10 0 0 1 12 2a10 10 0 0 1 10 10 10 10 0 0 1-10 10z"/></svg>
        </button>
        <button type="button" class="share-btn" data-share="email" aria-label="Compartir por email" title="Email">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </button>
        <button type="button" class="share-btn" data-share="copy" aria-label="Copiar enlace" title="Copiar enlace">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ==================== ERROR ==================== -->
<section class="cv-error" id="error" hidden>
  <div class="container">
    <div class="error-card">
      <h2>Algo salió mal</h2>
      <p id="error-message">Intenta de nuevo en un momento.</p>
      <button type="button" id="error-retry-btn" class="btn btn-primary">Intentar otra vez</button>
    </div>
  </div>
</section>

<!-- ==================== FOOTER ==================== -->
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="eyebrow eyebrow-light">
        <span class="dot"></span>
        <span>Solca · Ciencia y Consultoría</span>
      </div>
      <p>Acompañamiento profesional en la transición de academia a industria farmacéutica para PhDs en LATAM y España.</p>
    </div>
    <div class="footer-links">
      <h4>Recursos</h4>
      <a href="/revisar-cv">Análisis de CV</a>
      <a href="/#libros">Libros</a>
      <a href="/#curso">Curso CV+LinkedIn</a>
    </div>
    <div class="footer-links">
      <h4>Sitio</h4>
      <a href="/">Inicio</a>
      <a href="/#sobre">Sobre Solca</a>
      <a href="/contacto">Contacto</a>
      <a href="/privacidad">Privacidad</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2026 Oscar Omar Solís Castro · Solca · Ciencia y Consultoría. · <a href="/privacidad" style="color: inherit; text-decoration: underline;">Aviso de privacidad</a></p>
  </div>
</footer>

<style>
  /* Aseguramos que el atributo HTML `hidden` siempre gana sobre `display: flex/grid`.
     Sin esta regla, .pdf-warning[hidden] se ve igualmente porque su display: flex lo override. */
  [hidden] { display: none !important; }

  /* ============ CV Hero ============ */
  .cv-hero {
    position: relative;
    background:
      radial-gradient(ellipse at 80% 15%, rgba(232,116,58,0.13) 0%, transparent 55%),
      radial-gradient(ellipse at 15% 90%, rgba(42,107,172,0.18) 0%, transparent 55%),
      linear-gradient(135deg, var(--navy) 0%, var(--navy-deep) 100%);
    color: var(--off-white);
    padding: 80px 0 70px;
    overflow: hidden;
  }
  .cv-hero-inner { position: relative; z-index: 2; max-width: 820px; }
  .cv-hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 18px;
    color: var(--off-white);
  }
  .cv-hero-title em { font-style: normal; color: var(--orange); }
  .cv-hero-lead {
    font-size: 18px;
    line-height: 1.55;
    color: var(--off-white-mute);
    margin-bottom: 24px;
    max-width: 720px;
  }
  .cv-hero-meta {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
    margin-top: 10px;
  }
  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--off-white-mute);
  }
  .meta-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange);
  }

  /* ============ Form ============ */
  .cv-form-section { background: var(--bg); padding: 70px 0; }
  .cv-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    max-width: 820px;
    margin: 0 auto;
    background: var(--off-white);
    padding: 36px;
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
  }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field.full { grid-column: 1 / -1; }
  .field label {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: var(--text);
  }
  .field input, .field select, .field textarea {
    padding: 12px 14px;
    border: 1.5px solid var(--rule);
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: var(--text);
    background: white;
    transition: border-color 0.2s;
  }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: 0;
    border-color: var(--orange);
  }
  .field textarea {
    resize: vertical;
    min-height: 220px;
    line-height: 1.5;
    font-family: 'Inter', sans-serif;
  }
  .field-help {
    font-size: 12px;
    color: var(--text-mute);
    margin-top: 4px;
  }
  .optional-label {
    font-weight: 400;
    color: var(--text-mute);
    font-size: 13px;
  }
  .upload-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    padding: 14px;
    background: var(--bg);
    border: 1.5px dashed var(--rule);
    border-radius: 8px;
    margin-bottom: 4px;
  }
  .upload-wrap input[type="file"] {
    flex: 1;
    min-width: 200px;
    padding: 0;
    border: 0;
    background: transparent;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: var(--text);
  }
  .upload-wrap input[type="file"]::file-selector-button {
    padding: 8px 14px;
    margin-right: 12px;
    border: 0;
    border-radius: 6px;
    background: var(--navy);
    color: var(--off-white);
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
  }
  .upload-wrap input[type="file"]::file-selector-button:hover {
    background: var(--navy-deep);
  }
  .upload-status {
    font-size: 13px;
    color: var(--text-mute);
    font-family: 'Inter', sans-serif;
  }
  .upload-status.success { color: var(--orange); font-weight: 600; }
  .upload-status.error { color: #C04040; font-weight: 600; }

  .textarea-collapsed {
    margin-top: 8px;
    padding: 14px 18px;
    background: rgba(232,116,58,0.08);
    border: 1px solid rgba(232,116,58,0.20);
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .textarea-toggle-btn {
    background: transparent;
    border: 1.5px solid var(--orange);
    color: var(--orange);
    padding: 8px 16px;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .textarea-toggle-btn:hover {
    background: var(--orange);
    color: var(--off-white);
  }

  /* PDF parsing failure callout · ATS pista */
  .pdf-warning {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background: rgba(232,116,58,0.06);
    border: 1.5px solid rgba(232,116,58,0.30);
    border-left: 4px solid var(--orange);
    border-radius: 8px;
    padding: 18px 22px;
    margin: 6px 0 14px;
  }
  .pdf-warning-icon {
    flex-shrink: 0;
    color: var(--orange);
    margin-top: 2px;
  }
  .pdf-warning-content { flex: 1; min-width: 0; }
  .pdf-warning h4 {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 17px;
