---
// Admin de códigos beta del Simulador (Fase 1.5.G · 19 jun 2026).
// Auth por ?key=<STATS_KEY>. Lee de /api/simulator-beta-codes.
// Muestra tabla con estado (activo/agotado/expirado), cohort, sessions
// remaining, y link para copiar la URL de invitación.
export const prerender = false;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Solca · Admin · Códigos beta</title>
  <style>
    :root {
      --navy: #1B3A6B;
      --navy-deep: #0F2748;
      --orange: #E8743A;
      --off-white: #F7F5EE;
      --text: #1B2540;
      --text-mute: #5A6480;
      --rule: #DCDAD2;
      --green: #5A8A3A;
      --red: #C44A3A;
      --bg: #FAFAF7;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0; font-family: -apple-system, 'Segoe UI', Roboto, 'Inter', sans-serif;
      background: var(--bg); color: var(--text); line-height: 1.5;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 24px 28px 80px; }
    header.page-head {
      display: flex; align-items: baseline; justify-content: space-between;
      flex-wrap: wrap; gap: 16px;
      padding-bottom: 18px; border-bottom: 1px solid var(--rule);
      margin-bottom: 28px;
    }
    .page-title { font-size: 26px; font-weight: 800; color: var(--navy); margin: 0; letter-spacing: -0.01em; }
    .page-meta { font-size: 13px; color: var(--text-mute); }
    .reload-btn {
      background: var(--orange); color: white; border: none; padding: 8px 14px;
      border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 13px;
    }
    .reload-btn:hover { background: #d96632; }
    .auth-error, .empty-state {
      padding: 28px; background: white; border: 1px solid var(--rule);
      border-radius: 8px; max-width: 560px; margin: 60px auto;
    }
    .auth-error h2 { color: var(--red); margin-top: 0; }
    .auth-error code { background: var(--off-white); padding: 2px 6px; border-radius: 4px; font-size: 13px; }
    .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-bottom: 24px; }
    .kpi-card { background: white; border: 1px solid var(--rule); border-radius: 8px; padding: 14px 16px; }
    .kpi-label { font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-mute); font-weight: 600; }
    .kpi-value { font-size: 26px; font-weight: 800; color: var(--navy); margin-top: 4px; line-height: 1.1; }
    .kpi-sub { font-size: 12px; color: var(--text-mute); margin-top: 2px; }
    .cohort-row { display: flex; gap: 8px; flex-wrap: wrap; margin: 16px 0 24px; }
    .cohort-chip {
      background: white; border: 1px solid var(--rule); border-radius: 999px;
      padding: 4px 12px; font-size: 13px; color: var(--text);
    }
    table.codes {
      width: 100%; border-collapse: collapse; background: white;
      border: 1px solid var(--rule); border-radius: 8px; overflow: hidden;
    }
    table.codes th, table.codes td {
      padding: 10px 12px; text-align: left; font-size: 13px;
      border-bottom: 1px solid var(--rule);
    }
    table.codes th {
      background: var(--off-white); color: var(--text-mute); font-weight: 600;
      font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em;
    }
    table.codes tr:last-child td { border-bottom: none; }
    table.codes .codigo {
      font-family: 'SF Mono', Menlo, Consolas, monospace;
      font-weight: 700; color: var(--navy);
      letter-spacing: 0.04em;
    }
    .estado-pill {
      display: inline-block; padding: 2px 8px; border-radius: 999px;
      font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .estado-activo { background: rgba(90, 138, 58, 0.15); color: var(--green); }
    .estado-agotado { background: rgba(232, 116, 58, 0.15); color: var(--orange); }
    .estado-expirado { background: rgba(196, 74, 58, 0.15); color: var(--red); }
    .copy-btn {
      background: transparent; border: 1px solid var(--rule); padding: 4px 10px;
      border-radius: 6px; font-size: 12px; cursor: pointer; color: var(--navy);
    }
    .copy-btn:hover { background: var(--off-white); border-color: var(--navy); }
    .copy-btn.copied { background: var(--green); color: white; border-color: var(--green); }
    .footnote { font-size: 12px; color: var(--text-mute); margin-top: 24px; font-style: italic; }
  </style>
</head>
<body>
  <div class="container">
    <header class="page-head">
      <div>
        <h1 class="page-title">Códigos beta · Simulador</h1>
        <p class="page-meta" id="page-meta">Cargando…</p>
      </div>
      <button class="reload-btn" id="reload-btn">Recargar</button>
    </header>
    <div id="content"></div>
    <p class="footnote">Generados por scripts/generate-beta-codes.mjs · KV SIMULATOR_BETA_CODES · estado computado en vivo.</p>
  </div>

  <script>
    const contentEl = document.getElementById('content');
    const metaEl = document.getElementById('page-meta');
    const reloadBtn = document.getElementById('reload-btn');

    function escapeHtml(s) {
      return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function fmtDate(iso) {
      if (!iso) return '—';
      try { return new Date(iso).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' }); }
      catch { return iso; }
    }

    function showError(html) {
      contentEl.innerHTML = `<div class="auth-error">${html}</div>`;
      metaEl.textContent = 'No se cargaron datos.';
    }

    function render(data) {
      metaEl.textContent = `${data.total} códigos · generado ${new Date(data.generated_at).toLocaleTimeString('es-MX')}`;

      if (data.total === 0) {
        contentEl.innerHTML = `
          <div class="empty-state">
            <h2>Sin códigos todavía</h2>
            <p>Genera el primer batch con <code>scripts/generate-beta-codes.mjs</code>.</p>
          </div>
        `;
        return;
      }

      const kpis = `
        <div class="kpi-row">
          <div class="kpi-card">
            <div class="kpi-label">Activos</div>
            <div class="kpi-value">${data.by_estado.activo}</div>
            <div class="kpi-sub">aún pueden iniciar sesión</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">Agotados</div>
            <div class="kpi-value">${data.by_estado.agotado}</div>
            <div class="kpi-sub">consumieron todas sus sesiones</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">Expirados</div>
            <div class="kpi-value">${data.by_estado.expirado}</div>
            <div class="kpi-sub">pasó el expires_at sin agotarse</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">Total cohorts</div>
            <div class="kpi-value">${Object.keys(data.by_cohort).length}</div>
          </div>
        </div>
      `;

      const cohortChips = Object.entries(data.by_cohort)
        .sort((a, b) => b[1] - a[1])
        .map(([c, n]) => `<span class="cohort-chip"><strong>${escapeHtml(c)}</strong> · ${n}</span>`)
        .join('');

      const tableRows = data.codes.map((c) => `
        <tr>
          <td><span class="codigo">${escapeHtml(c.codigo)}</span></td>
          <td>${escapeHtml(c.nombre_pila || '—')}</td>
          <td><span class="estado-pill estado-${c.estado}">${c.estado}</span></td>
          <td>${c.sessions_used} / ${c.max_sessions}</td>
          <td>${escapeHtml(c.cohort || '—')}</td>
          <td>${fmtDate(c.granted_at)}</td>
          <td>${fmtDate(c.expires_at)}</td>
          <td><button class="copy-btn" data-url="${escapeHtml(c.url)}">Copiar URL</button></td>
        </tr>
      `).join('');

      contentEl.innerHTML = `
        ${kpis}
        <div class="cohort-row">${cohortChips}</div>
        <table class="codes">
          <thead>
            <tr>
              <th>Código</th>
              <th>Nombre</th>
              <th>Estado</th>
              <th>Sesiones</th>
              <th>Cohort</th>
              <th>Otorgado</th>
              <th>Expira</th>
              <th></th>
            </tr>
          </thead>
          <tbody>${tableRows}</tbody>
        </table>
      `;

      // Wire up copy buttons
      contentEl.querySelectorAll('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const url = btn.getAttribute('data-url');
          if (!url) return;
          try {
            await navigator.clipboard.writeText(url);
            const originalText = btn.textContent;
            btn.textContent = 'Copiado';
            btn.classList.add('copied');
            setTimeout(() => {
              btn.textContent = originalText;
              btn.classList.remove('copied');
            }, 1500);
          } catch (err) {
            console.error('Copy failed:', err);
            btn.textContent = 'Error';
          }
        });
      });
    }

    async function load() {
      const params = new URLSearchParams(window.location.search);
      const key = params.get('key');
      if (!key) {
        showError(`
          <h2>Acceso restringido</h2>
          <p>Esta página es interna. Agrega <code>?key=&lt;STATS_KEY&gt;</code> al URL.</p>
        `);
        return;
      }

      metaEl.textContent = 'Cargando códigos…';
      contentEl.innerHTML = '';

      try {
        const resp = await fetch(`/api/simulator-beta-codes?key=${encodeURIComponent(key)}`);
        if (resp.status === 401) {
          showError(`<h2>Clave incorrecta</h2><p><code>?key=</code> no coincide con <code>STATS_KEY</code>.</p>`);
          return;
        }
        if (resp.status === 503) {
          const e = await resp.json().catch(() => ({}));
          showError(`<h2>Servicio no disponible</h2><p>${escapeHtml(e.message || e.error || '')}</p>`);
          return;
        }
        if (!resp.ok) {
          const e = await resp.json().catch(() => ({}));
          showError(`<h2>Error ${resp.status}</h2><pre>${escapeHtml(JSON.stringify(e, null, 2))}</pre>`);
          return;
        }
        const data = await resp.json();
        render(data);
      } catch (err) {
        showError(`<h2>Error de red</h2><p>${escapeHtml(err && err.message ? err.message : String(err))}</p>`);
      }
    }

    reloadBtn.addEventListener('click', load);
    load();
  </script>
</body>
</html>
