---
// Layout for individual blog posts. Wraps BaseLayout, injects Schema.org Article JSON-LD,
// and renders the canonical post chrome (hero, byline, category badge, prose, CTA).
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data } = post;

const siteUrl = Astro.site?.toString() ?? 'https://solcaciencia.com/';
const postUrl = new URL(`/blog/${post.id}/`, siteUrl).toString();
const heroImageURL = data.heroImage.startsWith('http')
  ? data.heroImage
  : new URL(data.heroImage, siteUrl).toString();

// Format dates in es-MX for human display.
const formatDate = (d: Date) =>
  d.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });

// Compute reading minutes if not provided (approx 220 wpm Spanish prose).
const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingMinutes = data.readingMinutes ?? Math.max(2, Math.round(wordCount / 220));

const categoryLabel =
  data.category === 'carreras-pharma' ? 'Carreras pharma' : 'Academia → industria';

// JSON-LD Article schema for Google rich results.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  image: [heroImageURL],
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: data.author,
    url: 'https://solcaciencia.com/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Solca · Ciencia y Consultoría',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/og-image.png', siteUrl).toString(),
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': postUrl,
  },
  inLanguage: 'es-ES',
  articleSection: categoryLabel,
  keywords: data.tags.join(', '),
};
---
<BaseLayout
  title={`${data.title} · Solca`}
  description={data.description}
  ogImage={data.heroImage}
  ogType="article"
  canonicalOverride={data.canonical ?? postUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- ==================== NAV ==================== -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <span class="dot"></span>
        <span>Solca</span>
      </a>
      <div class="nav-links">
        <a href="/blog">Blog</a>
        <a href="/quiz-rol">Quiz</a>
        <a href="/revisar-cv">Revisar CV</a>
        <a href="/contacto">Contacto</a>
      </div>
    </div>
  </nav>

  <!-- ==================== POST ==================== -->
  <article class="post">
    <header class="post-header">
      <div class="container post-header-inner">
        <a href="/blog" class="post-back">← Volver al blog</a>
        <div class="post-meta-top">
          <span class="post-category">{categoryLabel}</span>
          <span class="post-meta-sep">·</span>
          <time datetime={data.pubDate.toISOString()}>{formatDate(data.pubDate)}</time>
          <span class="post-meta-sep">·</span>
          <span>{readingMinutes} min de lectura</span>
        </div>
        <h1 class="post-title">{data.title}</h1>
        <p class="post-description">{data.description}</p>
        {data.series && data.seriesIndex && (
          <div class="post-series">
            Serie · <strong>{data.series.replace(/-/g, ' ')}</strong> · entrega #{data.seriesIndex}
          </div>
        )}
      </div>
    </header>

    <div class="post-hero">
      <div class="container">
        <img src={data.heroImage} alt={data.title} loading="eager" />
      </div>
    </div>

    <div class="post-body">
      <div class="container post-body-inner">
        <div class="post-prose">
          <slot />
        </div>

        {data.tags.length > 0 && (
          <ul class="post-tags" aria-label="Etiquetas">
            {data.tags.map((tag) => <li>#{tag}</li>)}
          </ul>
        )}

        <aside class="post-cta">
          <div class="post-cta-eyebrow">
            <span class="dot"></span>
            <span>¿Listo para el siguiente paso?</span>
          </div>
          <h2>Analiza tu CV gratis con Solca</h2>
          <p>
            Subes tu CV, respondes 4 preguntas y recibes feedback estructurado por la lente de un reclutador pharma LATAM. Sin email obligatorio, sin redirecciones.
          </p>
          <a href="/revisar-cv" class="btn btn-primary">Revisar mi CV →</a>
        </aside>

        {data.updatedDate && (
          <p class="post-updated">
            Última actualización: <time datetime={data.updatedDate.toISOString()}>{formatDate(data.updatedDate)}</time>
          </p>
        )}
      </div>
    </div>

    <footer class="post-footer">
      <div class="container">
        <p>
          ¿Te sirvió? Comparte el link con alguien que lo necesite. Si quieres recibir los próximos en LinkedIn,
          <a href="https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7432492458158120960" target="_blank" rel="noopener">suscríbete al newsletter Solca Insight</a>.
        </p>
      </div>
    </footer>
  </article>

  <style is:global>
    /* ============ Nav ============ */
    .nav {
      position: sticky; top: 0; z-index: 50;
      background: rgba(250, 249, 244, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--rule);
    }
    .nav-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 14px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-brand {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 18px;
      color: var(--text);
      display: flex; align-items: center; gap: 10px;
    }
    .nav-links {
      display: flex; gap: 28px;
    }
    .nav-links a {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-mute);
    }
    .nav-links a:hover { color: var(--navy); opacity: 1; }

    /* ============ Post header ============ */
    .post-header {
      padding: 56px 0 32px;
      background: var(--bg);
    }
    .post-header-inner { display: flex; flex-direction: column; gap: 18px; }
    .post-back {
      font-size: 14px;
      color: var(--text-mute);
      font-weight: 500;
    }
    .post-meta-top {
      display: flex; gap: 8px; flex-wrap: wrap;
      font-size: 14px;
      color: var(--text-mute);
    }
    .post-category {
      color: var(--orange);
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 12px;
      padding: 4px 0;
    }
    .post-meta-sep { color: var(--rule); }
    .post-title {
      font-family: 'Inter', sans-serif;
      font-weight: 800;
      font-size: clamp(32px, 5vw, 56px);
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--text);
      max-width: 920px;
    }
    .post-description {
      font-size: 21px;
      line-height: 1.5;
      color: var(--text-mute);
      max-width: 820px;
    }
    .post-series {
      font-size: 13px;
      color: var(--text-mute);
      font-family: 'Space Grotesk', sans-serif;
      letter-spacing: 0.04em;
    }

    /* ============ Hero ============ */
    .post-hero { padding: 8px 0 32px; }
    .post-hero img {
      width: 100%;
      max-width: var(--max-w);
      border-radius: var(--radius);
      box-shadow: var(--shadow-md);
    }

    /* ============ Body / prose ============ */
    .post-body { padding: 24px 0 80px; }
    .post-body-inner { max-width: 760px !important; }
    .post-prose {
      font-size: 19px;
      line-height: 1.7;
      color: var(--text);
    }
    .post-prose > * + * { margin-top: 1.1em; }
    .post-prose h2 {
      font-family: 'Inter', sans-serif;
      font-weight: 800;
      font-size: 30px;
      line-height: 1.2;
      letter-spacing: -0.015em;
      margin-top: 2.2em;
      color: var(--text);
    }
    .post-prose h3 {
      font-family: 'Inter', sans-serif;
      font-weight: 700;
      font-size: 22px;
      line-height: 1.3;
      margin-top: 1.8em;
      color: var(--text);
    }
    .post-prose p { color: var(--text); }
    .post-prose strong { color: var(--text); font-weight: 700; }
    .post-prose a {
      color: var(--navy);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
      text-decoration-color: rgba(27,58,107,0.3);
    }
    .post-prose a:hover {
      text-decoration-color: var(--orange);
      color: var(--orange);
      opacity: 1;
    }
    .post-prose ul, .post-prose ol { padding-left: 1.4em; }
    .post-prose li { margin-bottom: 0.5em; }
    .post-prose blockquote {
      border-left: 3px solid var(--orange);
      padding-left: 20px;
      color: var(--text-mute);
      font-style: italic;
      margin: 1.5em 0;
    }
    .post-prose code {
      background: var(--orange-light);
      padding: 1px 6px;
      border-radius: 4px;
      font-size: 0.92em;
      font-family: 'SFMono-Regular', Menlo, monospace;
    }
    .post-prose pre {
      background: var(--navy-deep);
      color: var(--off-white);
      padding: 20px;
      border-radius: 10px;
      overflow-x: auto;
      font-size: 14px;
    }
    .post-prose pre code { background: transparent; padding: 0; color: inherit; }
    .post-prose img {
      border-radius: 10px;
      box-shadow: var(--shadow-sm);
      margin: 1.5em auto;
    }
    .post-prose table {
      width: 100%;
      border-collapse: collapse;
      font-size: 16px;
      margin: 1.5em 0;
    }
    .post-prose th, .post-prose td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--rule);
      text-align: left;
    }
    .post-prose th {
      font-weight: 700;
      color: var(--text);
      background: rgba(232,116,58,0.04);
    }
    .post-prose hr {
      border: 0;
      border-top: 1px solid var(--rule);
      margin: 2.5em 0;
    }

    /* ============ Tags ============ */
    .post-tags {
      display: flex; flex-wrap: wrap; gap: 8px;
      list-style: none; padding: 0;
      margin-top: 3em;
      padding-top: 1.5em;
      border-top: 1px solid var(--rule);
    }
    .post-tags li {
      font-size: 13px;
      color: var(--text-mute);
      background: var(--blue-soft);
      padding: 4px 10px;
      border-radius: 4px;
      font-family: 'Space Grotesk', sans-serif;
    }

    /* ============ CTA ============ */
    .post-cta {
      background: var(--navy);
      color: var(--off-white);
      border-radius: var(--radius);
      padding: 36px 32px;
      margin-top: 3.5em;
    }
    .post-cta .post-cta-eyebrow {
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 14px;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--orange);
    }
    .post-cta h2 {
      color: var(--off-white);
      font-size: 28px;
      line-height: 1.2;
      margin-bottom: 12px;
      font-weight: 800;
    }
    .post-cta p {
      color: var(--off-white-mute);
      font-size: 17px;
      line-height: 1.55;
      margin-bottom: 20px;
    }
    .post-cta .btn-primary {
      background: var(--orange);
      color: white;
      font-weight: 700;
    }
    .post-cta .btn-primary:hover {
      background: var(--orange-soft);
      opacity: 1;
    }

    .post-updated {
      margin-top: 2em;
      font-size: 13px;
      color: var(--text-mute);
      font-style: italic;
    }

    .post-footer {
      border-top: 1px solid var(--rule);
      padding: 32px 0 64px;
      background: var(--bg);
    }
    .post-footer p {
      font-size: 15px;
      color: var(--text-mute);
      max-width: 760px;
    }

    @media (max-width: 720px) {
      .post-header { padding: 32px 0 16px; }
      .post-prose { font-size: 17px; line-height: 1.65; }
      .post-prose h2 { font-size: 24px; }
      .post-prose h3 { font-size: 19px; }
      .post-cta { padding: 24px 20px; }
      .nav-links { gap: 16px; }
      .nav-links a { font-size: 13px; }
    }
  </style>
</BaseLayout>
